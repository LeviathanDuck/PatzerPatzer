{
  "name": "patzer-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "node build.mjs",
    "serve": "node server.mjs",
    "typecheck": "tsc --noEmit",
    "prompts:generate": "node scripts/generate-prompt-docs.mjs",
    "sprints:generate": "node scripts/generate-sprint-docs.mjs",
    "dashboard:generate": "node scripts/generate-prompt-dashboard.mjs",
    "prompts:refresh": "npm run prompts:generate && npm run sprints:generate && npm run dashboard:generate && npm run audit:prompts && npm run audit:sprints",
    "sprints:refresh": "npm run prompts:generate && npm run sprints:generate && npm run dashboard:generate && npm run audit:prompts && npm run audit:sprints",
    "prompts:migrate": "node scripts/migrate-prompt-registry.mjs && npm run prompts:generate",
    "audit:prompts": "node scripts/audit-prompt-tracking.mjs",
    "audit:sprints": "node scripts/audit-sprint-tracking.mjs",
    "sprint:recompute": "node scripts/sprint-recompute.mjs",
    "sprint:audit:complete": "node scripts/sprint-audit-complete.mjs",
    "sprint:panel-note:set": "node scripts/sprint-panel-note.mjs",
    "sprint:panel-note:clear": "node scripts/sprint-panel-note.mjs --clear",
    "sprint:seed": "node scripts/sprint-seed.mjs",
    "prompts:dashboard": "node scripts/generate-prompt-dashboard.mjs",
    "prompt:reserve": "node scripts/prompt-reserve.mjs",
    "prompt:reserve-followup": "node scripts/prompt-reserve-followup.mjs",
    "prompt:create": "node scripts/prompt-create.mjs",
    "prompts:repair-active": "node scripts/repair-active-prompt-bodies.mjs",
    "prompt:reservations": "node scripts/prompt-reservations.mjs",
    "prompt:release": "node scripts/prompt-release.mjs",
    "prompt:start": "node scripts/prompt-start.mjs",
    "prompt:skip": "node scripts/prompt-skip.mjs",
    "prompt:complete": "node scripts/prompt-complete.mjs",
    "prompt:review": "node scripts/prompt-review.mjs",
    "prompt:campaign:status": "node scripts/prompt-review-campaign-status.mjs",
    "sprint:create": "node scripts/sprint-create.mjs",
    "sprint:backfill": "node scripts/sprint-backfill.mjs",
    "sprint:status": "node scripts/sprint-status.mjs",
    "generate:master-games": "node scripts/generate-master-games.mjs",
    "lookbook:generate": "npx tsx scripts/generate-patzer-lookbook.mjs"
  },
  "dependencies": {
    "@lichess-org/chessground": "^10.1.0",
    "@lichess-org/stockfish-web": "^0.2.3",
    "better-sqlite3": "^12.8.0",
    "chessops": "^0.15.0",
    "snabbdom": "^3.6.2",
    "stockfish": "^16.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "sass": "^1.86.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "better-sqlite3"
    ]
  }
}
