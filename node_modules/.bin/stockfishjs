#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/leftcoast/Development/PatzerPatzer/node_modules/.pnpm/stockfish@16.0.0/node_modules/stockfish/node_modules:/Users/leftcoast/Development/PatzerPatzer/node_modules/.pnpm/stockfish@16.0.0/node_modules:/Users/leftcoast/Development/PatzerPatzer/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/leftcoast/Development/PatzerPatzer/node_modules/.pnpm/stockfish@16.0.0/node_modules/stockfish/node_modules:/Users/leftcoast/Development/PatzerPatzer/node_modules/.pnpm/stockfish@16.0.0/node_modules:/Users/leftcoast/Development/PatzerPatzer/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
"$basedir/../stockfish/stockfishjs"   "$@"
exit $?
